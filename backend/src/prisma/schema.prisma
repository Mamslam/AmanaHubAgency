generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  PROSPECT
  AUDITED
  EMAILED
  REPLIED
  NEGOTIATING
  CLOSED
  DELIVERED
  COLD
}

enum EmailType {
  OUTREACH
  FOLLOWUP_1
  FOLLOWUP_2
}

enum EmailStatus {
  DRAFT
  SENT
  REPLIED
  BOUNCED
}

enum DealStatus {
  NEGOTIATING
  CLOSED
  CANCELLED
}

enum InvoiceStatus {
  PENDING
  SENT
  PAID
  OVERDUE
}

model Lead {
  id            String     @id @default(cuid())
  domain        String     @unique
  businessName  String?
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  city          String?
  country       String?
  niche         String?
  language      String     @default("EN")
  aigencyIssues String[]
  leadScore     Int?
  status        LeadStatus @default(PROSPECT)
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  audits        Audit[]
  emails        Email[]
  deals         Deal[]
}

model Audit {
  id             String   @id @default(cuid())
  leadId         String
  lead           Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  scores         Json
  issues         Json
  roiAnalysis    Json
  dynamicPricing Json
  outreachEmails Json
  pdfUrl         String?
  createdAt      DateTime @default(now())
}

model Email {
  id        String      @id @default(cuid())
  leadId    String
  lead      Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  subject   String
  body      String      @db.Text
  language  String
  pdfUrl    String?
  sentAt    DateTime?
  repliedAt DateTime?
  gmailId   String?
  type      EmailType   @default(OUTREACH)
  status    EmailStatus @default(DRAFT)
  createdAt DateTime    @default(now())
}

model Deal {
  id           String        @id @default(cuid())
  leadId       String
  lead         Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  services     Json
  oneTimeValue Float
  monthlyValue Float         @default(0)
  status       DealStatus    @default(NEGOTIATING)
  closedAt     DateTime?
  invoices     Invoice[]
  deliverables Deliverable[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Invoice {
  id        String        @id @default(cuid())
  dealId    String
  deal      Deal          @relation(fields: [dealId], references: [id], onDelete: Cascade)
  number    String        @unique
  amount    Float
  vatAmount Float         @default(0)
  total     Float
  pdfUrl    String?
  stripeUrl String?
  status    InvoiceStatus @default(PENDING)
  dueDate   DateTime
  paidAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Deliverable {
  id          String    @id @default(cuid())
  dealId      String
  deal        Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  service     String
  checklist   Json
  completedAt DateTime?
  createdAt   DateTime  @default(now())
}

model AgentLog {
  id        String   @id @default(cuid())
  message   String
  level     String   @default("info")
  leadId    String?
  createdAt DateTime @default(now())
}

model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
